# Mealie MCP Server example environment.
# Copy this file to .env and replace the placeholder values.

# Required: URL reachable from the MCP server container/process.
# Docker Compose on the same host: http://host.docker.internal:9000
# Shared Docker network: http://mealie:9000
# Remote Mealie instance: https://mealie.example.com
MEALIE_BASE_URL=http://host.docker.internal:9000

# Required: create a dedicated API token in Mealie from your user profile.
MEALIE_API_TOKEN=replace-with-your-mealie-api-token

# Host port published by docker-compose.yml. The container always listens on 8080.
MCP_HTTP_PORT=8080

# Optional MCP server settings.
MCP_SERVER_NAME=Mealie MCP Server
MCP_HOST=0.0.0.0
MCP_PORT=8080

# Optional runtime settings.
LOG_LEVEL=INFO
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Optional: used only by docker-compose.integration.yml.
MEALIE_DOCKER_NETWORK=mealie_default
